# 🔐 SECURITY WARNING: NEVER COMMIT .env FILE TO GITHUB!
# This file contains sensitive credentials. Always keep in .gitignore.
# Copy this file to .env and fill in your actual values.

# Google Gemini API
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Backend Server
PORT=3000
CLIENT_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:3000

# Python ML API
# URL for FastAPI classifier service
CLASSIFIER_API_URL=http://127.0.0.1:8000

# Optional: MongoDB for persistent storage
# Leave empty to skip MongoDB (will use in-memory cache)
# For local: mongodb://127.0.0.1:27017
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=
MONGODB_DB_NAME=mindspace_ai

# Data Science Dashboard
VITE_STREAMLIT_URL=http://localhost:8501

# Environment (development or production)
NODE_ENV=development

